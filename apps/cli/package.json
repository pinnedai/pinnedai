{
  "name": "pinnedai",
  "version": "0.3.3",
  "description": "Smoke-test AI-built features so they actually work — not just parse. `pinned smoke add` runs your endpoint and asserts real invariants (non-empty, terminal state within bound, rejects bad input, errors on faults). Catches the AI-shipped-but-never-works bug class. Plus regression net for Server Actions / paid-API calls / Edge Functions / cron / webhooks / journeys, cross-repo enum-drift contracts, FP suppression store, readiness gate, AI-lesson injection at PreToolUse. Free beta · Founder Pro waitlist open.",
  "type": "module",
  "license": "Apache-2.0",
  "bin": {
    "pinned": "dist/cli.js"
  },
  "files": [
    "dist",
    "scripts/postinstall.cjs",
    "vscode-extension.vsix",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --target node20 --out-dir dist --shims --clean",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/postinstall.cjs",
    "prepublishOnly": "cp ../../README.md ./README.md"
  },
  "keywords": [
    "ci",
    "pr",
    "code-review",
    "ai-coding",
    "cursor",
    "claude-code",
    "devin",
    "github-actions",
    "test-generation",
    "regression-prevention"
  ],
  "author": "Michael Zon",
  "homepage": "https://pinnedai.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pinnedai/pinnedai.git"
  },
  "bugs": {
    "url": "https://github.com/pinnedai/pinnedai/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "12.1.0"
  },
  "peerDependencies": {
    "vitest": ">=1 <4"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "20.19.9",
    "tsup": "8.5.1",
    "tsx": "4.20.0",
    "typescript": "5.6.3",
    "vitest": "2.1.9"
  }
}
